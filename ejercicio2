
--Ejercicio 2
CREATE OR REPLACE TYPE T_PERSONA AS OBJECT (
    codi NUMBER,
    dni VARCHAR2(10),
    nom VARCHAR2(50),
    adreca VARCHAR2(100),
    telefon VARCHAR2(15)
) NOT FINAL;
/

-- Nivel 1: Hijos de Persona
CREATE OR REPLACE TYPE T_EMPLEAT UNDER T_PERSONA (
    sou NUMBER,
    data_contracte DATE,
    correu_corporatiu VARCHAR2(100),
    departament VARCHAR2(50),
    MEMBER FUNCTION antiguitat RETURN NUMBER
) NOT FINAL;
/

CREATE OR REPLACE TYPE T_ALUMNE UNDER T_PERSONA (
    num_expedient VARCHAR2(20),
    correu VARCHAR2(100),
    data_naixement DATE,
    MEMBER FUNCTION edat RETURN NUMBER
) NOT FINAL;
/

-- Nivel 2: Hijos de Empleat
CREATE OR REPLACE TYPE T_INVESTIGADOR UNDER T_EMPLEAT (
    especialitat VARCHAR2(50),
    num_publicacions NUMBER,
    MEMBER FUNCTION nivell_recerca RETURN VARCHAR2
);
/

CREATE OR REPLACE TYPE T_ADMINISTRATIU UNDER T_EMPLEAT (
    carrec VARCHAR2(50),
    tipus_jornada VARCHAR2(20),
    MEMBER FUNCTION sou_anual RETURN NUMBER
);
/

-- Nivel 2: Hijos de Alumne (con Atributos y Declaración de Constructor)
CREATE OR REPLACE TYPE T_ALUMNE_GRAU UNDER T_ALUMNE (
    titulacio VARCHAR2(50),
    durada NUMBER,
    any_1a_matricula NUMBER,
    CONSTRUCTOR FUNCTION T_ALUMNE_GRAU(codi NUMBER, dni VARCHAR2, nom VARCHAR2, adreca VARCHAR2, telefon VARCHAR2, num_expedient VARCHAR2, correu VARCHAR2, data_naixement DATE, titulacio VARCHAR2) RETURN SELF AS RESULT,
    MEMBER FUNCTION anys_restants RETURN NUMBER
);
/

CREATE OR REPLACE TYPE T_ALUMNE_MASTER UNDER T_ALUMNE (
    programa VARCHAR2(100),
    especialitat VARCHAR2(50),
    num_moduls NUMBER,
    CONSTRUCTOR FUNCTION T_ALUMNE_MASTER(codi NUMBER, dni VARCHAR2, nom VARCHAR2, adreca VARCHAR2, telefon VARCHAR2, num_expedient VARCHAR2, correu VARCHAR2, data_naixement DATE) RETURN SELF AS RESULT,
    MEMBER FUNCTION resum_estudis RETURN VARCHAR2
);
/
-- Cuerpo para Investigador (Soluciona tu error actual)
CREATE OR REPLACE TYPE BODY T_INVESTIGADOR AS
    MEMBER FUNCTION nivell_recerca RETURN VARCHAR2 IS
    BEGIN
        IF self.num_publicacions < 5 THEN 
            RETURN 'Inicial';
        ELSIF self.num_publicacions <= 15 THEN 
            RETURN 'Consolidat';
        ELSE 
            RETURN 'Senior';
        END IF;
    END;
END;
/
-- Cuerpo para Alumne Grau (Constructor y Función)
CREATE OR REPLACE TYPE BODY T_ALUMNE_GRAU AS
    CONSTRUCTOR FUNCTION T_ALUMNE_GRAU(codi NUMBER, dni VARCHAR2, nom VARCHAR2, adreca VARCHAR2, telefon VARCHAR2, num_expedient VARCHAR2, correu VARCHAR2, data_naixement DATE, titulacio VARCHAR2) RETURN SELF AS RESULT IS
    BEGIN
        self.codi := codi; self.dni := dni; self.nom := nom; self.adreca := adreca; self.telefon := telefon;
        self.num_expedient := num_expedient; self.correu := correu; self.data_naixement := data_naixement;
        self.titulacio := titulacio;
        self.durada := 4; 
        self.any_1a_matricula := EXTRACT(YEAR FROM SYSDATE);
        RETURN;
    END;
    MEMBER FUNCTION anys_restants RETURN NUMBER IS
    BEGIN
        RETURN self.durada - (EXTRACT(YEAR FROM SYSDATE) - self.any_1a_matricula);
    END;
END;
/

-- Cuerpo para Alumne Master (ESTE ES EL QUE TE DA EL ERROR)
CREATE OR REPLACE TYPE BODY T_ALUMNE_MASTER AS
    CONSTRUCTOR FUNCTION T_ALUMNE_MASTER(codi NUMBER, dni VARCHAR2, nom VARCHAR2, adreca VARCHAR2, telefon VARCHAR2, num_expedient VARCHAR2, correu VARCHAR2, data_naixement DATE) RETURN SELF AS RESULT IS
    BEGIN
        self.codi := codi; self.dni := dni; self.nom := nom; self.adreca := adreca; self.telefon := telefon;
        self.num_expedient := num_expedient; self.correu := correu; self.data_naixement := data_naixement;
        self.programa := 'Màster en Enginyeria del Software'; 
        self.especialitat := 'Arquitectura';
        self.num_moduls := 10;
        RETURN;
    END;
    MEMBER FUNCTION resum_estudis RETURN VARCHAR2 IS
    BEGIN
        RETURN 'Programa: ' || self.programa || ', Esp: ' || self.especialitat || ', Mòduls: ' || self.num_moduls;
    END;
END;
/
-- Cuerpo para Administratiu (Para que no te falle el siguiente)
CREATE OR REPLACE TYPE BODY T_ADMINISTRATIU AS
    MEMBER FUNCTION sou_anual RETURN NUMBER IS
    BEGIN
        RETURN self.sou * 14;
    END;
END;
/
-- Cuerpo para Alumne (Contiene la función edat que heredarán los demás)
CREATE OR REPLACE TYPE BODY T_ALUMNE AS
    MEMBER FUNCTION edat RETURN NUMBER IS
    BEGIN
        RETURN EXTRACT(YEAR FROM SYSDATE) - EXTRACT(YEAR FROM self.data_naixement);
    END;
END;
/

-- Cuerpo para Empleat (Contiene la función antiguitat que heredarán los demás)
CREATE OR REPLACE TYPE BODY T_EMPLEAT AS
    MEMBER FUNCTION antiguitat RETURN NUMBER IS
    BEGIN
        RETURN EXTRACT(YEAR FROM SYSDATE) - EXTRACT(YEAR FROM self.data_contracte);
    END;
END;
/
